[flake8]
max-line-length = 120
extend-ignore =
    # Line too long — SQL strings and format strings routinely exceed 120 chars
    E501,
    # Module-level imports not at top of file — scripts use sys.path.insert pattern
    E402,
    # Line break before binary operator — Black-compatible style
    W503,
    # Multiple spaces before operator/keyword — intentional column alignment in data tables
    E221,E272,
per-file-ignores =
    # Test files: allow longer lines for assertion messages
    tests/*.py: E501
    # dashboard.py is a large generated HTML/JS template module; relax blank-line spacing there
    scripts/dashboard.py: E303,E305
