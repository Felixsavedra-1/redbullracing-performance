ints_accumulated - prev_points, points_accumulated) as points_gained\nfrom base\norder by season desc, round", "relation_name": "\"f1_analytics\".\"main\".\"championship_progression\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-05-27T17:28:37.410450Z", "completed_at": "2026-05-27T17:28:37.416457Z"}, {"name": "execute", "started_at": "2026-05-27T17:28:37.417132Z", "completed_at": "2026-05-27T17:28:37.417135Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.009575366973876953, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.f1_analytics.pit_stop_efficiency", "compiled": true, "compiled_code": "select\n    r.season,\n    d.driver_name,\n    count(*)                             as total_stops,\n    min(ps.milliseconds)                 as fastest_stop_ms,\n    round(avg(ps.milliseconds), 0)       as avg_stop_ms,\n    max(ps.milliseconds)                 as slowest_stop_ms,\n    round(stddev(ps.milliseconds), 0)    as stddev_stop_ms\nfrom \"f1_analytics\".\"main\".\"stg_pit_stops\" ps\njoin \"f1_analytics\".\"main\".\"stg_races\"     r   on ps.race_id  = r.race_id\njoin \"f1_analytics\".\"main\".\"stg_drivers\"   d   on ps.driver_id = d.driver_id\njoin \"f1_analytics\".\"main\".\"results\" res\n    on ps.race_id = res.race_id and ps.driver_id = res.driver_id\nwhere res.constructor_id = 9\ngroup by r.season, d.driver_id, d.driver_name\norder by r.season desc, avg_stop_ms", "relation_name": "\"f1_analytics\".\"main\".\"pit_stop_efficiency\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-05-27T17:28:37.412416Z", "completed_at": "2026-05-27T17:28:37.416938Z"}, {"name": "execute", "started_at": "2026-05-27T17:28:37.417628Z", "completed_at": "2026-05-27T17:28:37.417631Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.009537935256958008, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.f1_analyti