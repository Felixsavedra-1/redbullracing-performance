_drivers_driver_id.a38f982d3a", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect driver_id\nfrom \"f1_analytics\".\"main\".\"stg_drivers\"\nwhere driver_id is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-05-05T02:08:28.411540Z", "completed_at": "2026-05-05T02:08:28.421678Z"}, {"name": "execute", "started_at": "2026-05-05T02:08:28.421986Z", "completed_at": "2026-05-05T02:08:28.421992Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.011949777603149414, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.f1_analytics.unique_stg_drivers_driver_id.4bdb9070a4", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    driver_id as unique_field,\n    count(*) as n_records\n\nfrom \"f1_analytics\".\"main\".\"stg_drivers\"\nwhere driver_id is not null\ngroup by driver_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-05-05T02:08:28.418280Z", "completed_at": "2026-05-05T02:08:28.422793Z"}, {"name": "execute", "started_at": "2026-05-05T02:08:28.423478Z", "completed_at": "2026-05-05T02:08:28.423482Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.01232600212097168, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.f1_analytics.pit_stop_efficiency", "compiled": true, "compiled_code": "select\n    r.season,\n    d.driver_name,\n    count(*)                             as total_stops,\n    min(ps.milliseconds)                 as fastest_stop_ms,\n    round(avg(ps.milliseconds), 0)       as avg_stop_ms,\n    max(ps.milliseconds)                 as slowest_stop_ms,\n    round(stddev(ps.milliseconds), 0)    as stddev_stop_ms\nfrom \"f1_analytics\".\"main\".\"stg_pit_stops\" ps\njoin \"f1_analytics\".\"main\".\"stg_races\"     r   on ps.race_id  = r.race_id\njoin \"f1_analytics\".\"main\".\"stg_drivers\"   d   on ps.driver_id = d.driver_id\njoin \"f1_analytics\".\"main\".\"results\" res\n    on ps.race_id = res.race_id and ps.driver_id = res.driver_id\nwhere res.constructor_id = 9\ngroup by r.season, d.driver_id, d.driver_name\norder by r.season desc, avg_stop_ms", "relation_name": "\"f1_analytics\".\"main\".\"pit_stop_efficiency\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-05-05T02:08:28.414751Z", "completed_at": "2026-05-05T02:08:28.422965Z"}, {"name": "execute", "started_at": "2026-05-05T02:08:28.423764Z", "completed_at": "2026-05-05T02:08:28.423766Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.013100624084472656, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.f1_analytics.championship_progression", "compiled": true, "compiled_code": "with base as (\n    select\n        r.season,\n        r.round,\n        r.race_name,\n        cs.position  as championship_position,\n        cs.points    as points_accumulated,\n        cs.wins      as wins_accumulated,\n        lag(cs.points) over (partition by r.season order by r.round) as prev_points\n    from \"f1_analytics\".\"main\".\"constructor_standings\" cs\n    join \"f1_analytics\".\"main\".\"stg_races\" r on cs.race_id = r.race_id\n    where cs.constructor_id = 9\n)\nselect\n    *,\n    coalesce(points_accumulated - prev_points, points_accumulated) as points_gained\nfrom base\norder by season desc, round", "relation_name": "\"f1_analytics\".\"main\".\"championship_progression\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-05-05T02:08:28.416352Z", "completed_at": "2026-05-05T02:08:28.423321Z"}, {"name": "execute", "started_at": "2026-05-05T02:08:28.426038Z", "completed_at": "2026-05-05T02:08:28.426042Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.015058040618896484, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.f1_analytics.driver_summary", "compiled": true, "compiled_code": "select\n    d.driver_name,\n    string_agg(distinct con.constructor_name, ', ') as team,\n    count(distinct r.season)                         as seasons,\n    count(*)                                         as races,\n    sum(res.points)                                  as points,\n    count(*) filter (where res.position = 1)         as wins,\n    count(*) filter (where res.position <= 3)        as podiums,\n    round(avg(res.position_order) filter (where not res.is_dnf), 1) as avg_finish,\n    count(*) filter (where res.is_dnf)               as dnfs,\n    min(r.season)                                    as from_season,\n    max(r.season)                                    as to_season\nfrom \"f1_analytics\".\"main\".\"stg_results\" res\njoin \"f1_analytics\".\"main\".\"stg_races\"   r   on res.race_id        = r.race_id\njoin \"f1_analytics\".\"main\".\"stg_drivers\" d   on res.driver_id      = d.driver_id\njoin \"f1_analytics\".\"main\".\"constructors\" con\n                                  on res.constructor_id = con.constructor_id\nwhere res.constructor_id = 9\ngroup by d.driver_id, d.driver_name\norder by points desc", "relation_name": "\"f1_analytics\".\"main\".\"driver_summary\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-05-05T02:08:28.424036Z", "completed_at": "2026-05-05T02:08:28.427447Z"}, {"name": "execute", "started_at": "2026-05-05T02:08:28.428134Z", "completed_at": "2026-05-05T02:08:28.428137Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005591154098510742, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.f1_analytics.qualifying_vs_race", "compiled": true, "compiled_code": "select\n    d.driver_name,\n    r.season,\n    count(*)                                                                          as races_started,\n    count(q.position)                                                                 as races_with_qualifying,\n    round(avg(q.position), 2)                                                         as avg_qual_position,\n    round(avg(res.position_order) filter (where not res.is_dnf), 2)                   as avg_race_position,\n    round(avg(cast(res.grid as integer) - res.position_order)\n          filter (where not res.is_dnf), 2)                                           as avg_positions_gained,\n    count(*) filter (where res.position_order < res.grid and not res.is_dnf)          as races_gained_positions\nfrom \"f1_analytics\".\"main\".\"stg_results\"   res\njoin \"f1_analytics\".\"main\".\"stg_races\"     r   on res.race_id  = r.race_id\njoin \"f1_analytics\".\"main\".\"stg_drivers\"   d   on res.driver_id = d.driver_id\nleft join \"f1_analytics\".\"main\".\"stg_qualifying\" q\n    on res.race_id = q.race_id and res.driver_id = q.driver_id\nwhere res.constructor_id = 9\ngroup by d.driver_id, d.driver_name, r.season\norder by r.season desc, avg_race_position", "relation_name": "\"f1_analytics\".\"main\".\"qualifying_vs_race\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-05-05T02:08:28.430799Z", "completed_at": "2026-05-05T02:08:28.435411Z"}, {"name": "execute", "started_at": "2026-05-05T02:08:28.435956Z", "completed_at": "2026-05-05T02:08:28.435962Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.008747100830078125, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.f1_analytics.not_null_stg_races_season.9595de9e62", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect season\nfrom \"f1_analytics\".\"main\".\"stg_races\"\nwhere season is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-05-05T02:08:28.428574Z", "completed_at": "2026-05-05T02:08:28.435584Z"}, {"name": "execute", "started_at": "2026-05-05T02:08:28.436471Z", "completed_at": "2026-05-05T02:08:2